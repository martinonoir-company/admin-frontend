# ── Admin frontend environment ──
# Copy this file to `.env.local` and fill in values for your environment.
# `.env.local` is git-ignored. Anything prefixed with NEXT_PUBLIC_ is
# inlined into the client bundle at build time — never put secrets here.

# Base URL of the API, including the /api/v1 version prefix.
#
#   Local dev:    http://localhost:3000/api/v1
#   Production:   https://api.martinonoir.com/api/v1   (nginx → backend)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
